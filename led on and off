#define BLYNK_TEMPLATE_NAME "TAMIL"
#define BLYNK_AUTH_TOKEN "GCuxYTkD_X4SlDXXZEE703foXmU6fO1R"
#define BLYNK_PRINT Serial
#include <WiFi.h>
#include <BlynkSimpleEsp32.h>
char ssid[] = "Network";
char pass[] = "Password";
#define LED_PIN 2   // ESP32 onboard LED
void setup()
{
  Serial.begin(115200);
  pinMode(LED_PIN, OUTPUT);
  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);
}
void loop()
{
  Blynk.run();
}
// When button V0 changes
BLYNK_WRITE(V0)
{
  int value = param.asInt();  // 0 or 1
  if (value == 1)
  {
    digitalWrite(LED_PIN, HIGH);   // LED ON
    Serial.println("LED ON");
  }
  else
  {
    digitalWrite(LED_PIN, LOW);    // LED OFF
    Serial.println("LED OFF");
  }
}